// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, UV);
	float n_out2p1 = n_out2p0.r;


// FloatOp:6
	float n_out6p0 = n_out12p0.x * n_out2p1;


// FloatOp:4
	float n_out4p0 = n_out3p4 * n_out6p0;


// Output:0
	ALBEDO = vec3(n_out3p0.xyz);
	ALPHA = n_out4p0;


}
