uniform sampler2D Aura_Texture : source_color;
uniform sampler2D tex_frg_2 : source_color;



void fragment() {
// Input:3
	vec4 n_out3p0 = COLOR;
	float n_out3p4 = n_out3p0.a;


// Input:8
	float n_out8p0 = TIME;


// Vector2Parameter:9
	vec2 n_out9p0 = Speed;


// FloatOp:10
